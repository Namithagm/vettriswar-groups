# Vettriswar Groups of Company — environment variables
# Copy this file to .env.local for local development, and set the same
# keys in your hosting provider's dashboard (e.g. Vercel Project Settings)
# for production. Nothing in this file is a real secret.

# ── Email (Resend) ──────────────────────────────────────────────────────
# Powers /api/contact and /api/newsletter. Create a free account at
# https://resend.com, verify a sending domain, and generate an API key.
RESEND_API_KEY=

# Address the contact form's "Send us a message" emails are delivered to.
# Falls back to lib/constants.ts -> SITE.emails.general if unset.
CONTACT_TO_EMAIL=info@vettriswargroups.com

# Display name + address the contact form emails are sent FROM.
# Must be a verified domain in your Resend account before going live.
CONTACT_FROM_EMAIL="Vettriswar Groups of Company <onboarding@resend.dev>"

# Resend Audience ID that newsletter signups are added to.
# Create an Audience in the Resend dashboard and paste its ID here.
RESEND_AUDIENCE_ID=

# ── Analytics (optional) ────────────────────────────────────────────────
# Google Analytics 4 Measurement ID (starts with "G-"). Leave blank to
# keep analytics disabled — the site works fully without it.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ── Vercel Analytics (optional) ─────────────────────────────────────────
# No environment variable needed — @vercel/analytics activates
# automatically when deployed on Vercel.
